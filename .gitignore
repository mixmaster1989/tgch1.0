# Node.js .gitignore

# Директория с зависимостями
node_modules/

# Пользовательская конфигурация
.env
.env.local
.env.development
.env.test
.env.production

# Логи
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Результаты тестов
coverage/
__tests__/
__mocks__/

# Билд-система
build/

# VSCode
.vscode/

# Системные файлы
.DS_Store
Thumbs.db

# Кэш
.cache
*.cache

# Тестовые данные
test-results/